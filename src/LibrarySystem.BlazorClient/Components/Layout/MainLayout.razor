@inherits LayoutComponentBase
@inject SessionService Session
@inject NavigationManager Nav

<div class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <i class="bi bi-book"></i> Библиотека
            </a>
            @if (Session.IsAuthenticated)
            {
                <div class="navbar-nav me-auto">
                    <a class="nav-link @NavClass("/")" href="/">Главная</a>
                    <a class="nav-link @NavClass("/books")" href="/books">Книги</a>
                    @if (Session.IsLibrarian)
                    {
                        <a class="nav-link @NavClass("/readers")" href="/readers">Читатели</a>
                        <a class="nav-link @NavClass("/loans")" href="/loans">Выдачи</a>
                        <a class="nav-link @NavClass("/statistics")" href="/statistics">Статистика</a>
                    }
                </div>
                <div class="d-flex align-items-center text-white">
                    <span class="me-3">
                        <i class="bi bi-person-circle"></i> @Session.Username
                        <span class="badge bg-light text-primary ms-1">@Session.Role</span>
                    </span>
                    <button class="btn btn-outline-light btn-sm" @onclick="Logout">
                        <i class="bi bi-box-arrow-right"></i> Выход
                    </button>
                </div>
            }
        </div>
    </nav>

    <main class="container-fluid flex-grow-1 py-4">
        @Body
    </main>

    <footer class="bg-light text-center py-2 text-muted small">
        LibrarySystem Client &copy; 2026 — CoreWCF Blazor Client (HTTP + TCP)
    </footer>
</div>

@code {
    protected override void OnInitialized()
    {
        Session.OnAuthStateChanged += StateHasChanged;
    }

    private void Logout()
    {
        Session.Logout();
        Nav.NavigateTo("/login");
    }

    private string NavClass(string href)
    {
        var relativePath = Nav.ToBaseRelativePath(Nav.Uri);
        return (href == "/" ? relativePath == "" : relativePath.StartsWith(href.TrimStart('/')))
            ? "active" : "";
    }
}

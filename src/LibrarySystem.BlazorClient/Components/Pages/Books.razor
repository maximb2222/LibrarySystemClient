@page "/books"
@inject LibraryApiClient Api
@inject SessionService Session
@inject NavigationManager Nav

@if (!Session.IsAuthenticated) { Nav.NavigateTo("/login"); return; }

<h3><i class="bi bi-book"></i> Каталог книг</h3>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible fade show">
        @message
        <button type="button" class="btn-close" @onclick="() => message = null"></button>
    </div>
}

<!-- Search -->
<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Название</label>
                <input class="form-control" @bind="searchTitle" placeholder="Поиск по названию..." />
            </div>
            <div class="col-md-3">
                <label class="form-label">Автор</label>
                <input class="form-control" @bind="searchAuthor" placeholder="Поиск по автору..." />
            </div>
            <div class="col-md-2">
                <label class="form-label">Жанр</label>
                <input class="form-control" @bind="searchGenre" placeholder="Жанр..." />
            </div>
            <div class="col-md-2">
                <div class="form-check mt-4">
                    <input class="form-check-input" type="checkbox" @bind="useTcp" id="tcpToggle" />
                    <label class="form-check-label" for="tcpToggle">TCP</label>
                </div>
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100" @onclick="LoadBooks">
                    <i class="bi bi-search"></i> Найти
                </button>
            </div>
        </div>
    </div>
</div>

@if (Session.IsLibrarian)
{
    <button class="btn btn-success mb-3" @onclick="ShowAddForm">
        <i class="bi bi-plus-lg"></i> Добавить книгу
    </button>
}

@if (showForm)
{
    <div class="card mb-3 border-primary">
        <div class="card-header bg-primary text-white">
            @(editingBook == null ? "Новая книга" : "Редактирование книги")
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Название *</label>
                    <input class="form-control" @bind="formBook.Title" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Автор *</label>
                    <input class="form-control" @bind="formBook.Author" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">ISBN</label>
                    <input class="form-control" @bind="formBook.ISBN" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Год</label>
                    <input type="number" class="form-control" @bind="formBook.Year" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Жанр</label>
                    <input class="form-control" @bind="formBook.Genre" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Экземпляры</label>
                    <input type="number" class="form-control" @bind="formBook.TotalCopies" />
                </div>
            </div>
            <div class="mt-3">
                <button class="btn btn-primary" @onclick="SaveBook">
                    <i class="bi bi-check-lg"></i> Сохранить
                </button>
                <button class="btn btn-secondary ms-2" @onclick="() => showForm = false">Отмена</button>
            </div>
        </div>
    </div>
}

@if (isLoading)
{
    <div class="text-center py-4">
        <div class="spinner-border text-primary"></div>
        <p class="mt-2">Загрузка...</p>
    </div>
}
else if (books != null)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Название</th>
                    <th>Автор</th>
                    <th>ISBN</th>
                    <th>Год</th>
                    <th>Жанр</th>
                    <th>Доступно</th>
                    <th>Транспорт</th>
                    @if (Session.IsLibrarian)
                    {
                        <th>Действия</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var book in books)
                {
                    <tr>
                        <td>@book.Id</td>
                        <td><strong>@book.Title</strong></td>
                        <td>@book.Author</td>
                        <td><code>@book.ISBN</code></td>
                        <td>@book.Year</td>
                        <td><span class="badge bg-secondary">@book.Genre</span></td>
                        <td>
                            <span class="badge @(book.AvailableCopies > 0 ? "bg-success" : "bg-danger")">
                                @book.AvailableCopies / @book.TotalCopies
                            </span>
                        </td>
                        <td><span class="badge @(useTcp ? "bg-warning" : "bg-info") transport-badge">@(useTcp ? "TCP" : "HTTP")</span></td>
                        @if (Session.IsLibrarian)
                        {
                            <td>
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => EditBook(book)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                @if (Session.IsAdmin)
                                {
                                    <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => DeleteBook(book.Id)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <p class="text-muted">Найдено книг: @books.Count</p>
}

@code {
    private List<BookDto>? books;
    private bool isLoading = true;
    private bool useTcp;
    private string? message;
    private bool isError;
    private string? searchTitle, searchAuthor, searchGenre;
    private bool showForm;
    private BookDto formBook = new();
    private BookDto? editingBook;

    protected override async Task OnInitializedAsync() => await LoadBooks();

    private async Task LoadBooks()
    {
        isLoading = true;
        try
        {
            var hasSearch = !string.IsNullOrWhiteSpace(searchTitle) ||
                            !string.IsNullOrWhiteSpace(searchAuthor) ||
                            !string.IsNullOrWhiteSpace(searchGenre);

            if (hasSearch)
            {
                books = await Api.SearchBooksAsync(Session.Token!, new SearchCriteriaDto
                {
                    Title = searchTitle,
                    Author = searchAuthor,
                    Genre = searchGenre
                }, useTcp);
            }
            else
            {
                books = await Api.GetAllBooksAsync(Session.Token!, useTcp);
            }
        }
        catch (Exception ex)
        {
            message = ErrorHandler.HandleException(ex);
            isError = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowAddForm()
    {
        editingBook = null;
        formBook = new BookDto { Year = DateTime.Now.Year, TotalCopies = 1 };
        showForm = true;
    }

    private void EditBook(BookDto book)
    {
        editingBook = book;
        formBook = new BookDto
        {
            Id = book.Id, Title = book.Title, Author = book.Author,
            ISBN = book.ISBN, Year = book.Year, Genre = book.Genre,
            TotalCopies = book.TotalCopies, AvailableCopies = book.AvailableCopies
        };
        showForm = true;
    }

    private async Task SaveBook()
    {
        try
        {
            if (editingBook != null)
            {
                await Api.UpdateBookAsync(Session.Token!, formBook, useTcp);
                message = $"Книга \"{formBook.Title}\" обновлена.";
            }
            else
            {
                var added = await Api.AddBookAsync(Session.Token!, formBook, useTcp);
                message = $"Книга \"{added.Title}\" добавлена (ID: {added.Id}).";
            }
            isError = false;
            showForm = false;
            await LoadBooks();
        }
        catch (Exception ex)
        {
            message = ErrorHandler.HandleException(ex);
            isError = true;
        }
    }

    private async Task DeleteBook(int id)
    {
        try
        {
            await Api.DeleteBookAsync(Session.Token!, id, useTcp);
            message = $"Книга #{id} удалена.";
            isError = false;
            await LoadBooks();
        }
        catch (Exception ex)
        {
            message = ErrorHandler.HandleException(ex);
            isError = true;
        }
    }
}

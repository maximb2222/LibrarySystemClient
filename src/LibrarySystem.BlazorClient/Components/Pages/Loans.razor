@page "/loans"
@inject LibraryApiClient Api
@inject SessionService Session
@inject NavigationManager Nav

@if (!Session.IsAuthenticated || !Session.IsLibrarian) { Nav.NavigateTo("/"); return; }

<h3><i class="bi bi-arrow-left-right"></i> Управление выдачами</h3>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible fade show">
        @message
        <button type="button" class="btn-close" @onclick="() => message = null"></button>
    </div>
}

<!-- Lend Book Form -->
<div class="card mb-3">
    <div class="card-header bg-warning text-dark">
        <i class="bi bi-plus-circle"></i> Выдать книгу
    </div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">ID книги</label>
                <input type="number" class="form-control" @bind="lendBookId" />
            </div>
            <div class="col-md-3">
                <label class="form-label">ID читателя</label>
                <input type="number" class="form-control" @bind="lendReaderId" />
            </div>
            <div class="col-md-2">
                <div class="form-check mt-2">
                    <input class="form-check-input" type="checkbox" @bind="useTcp" id="tcpL" />
                    <label class="form-check-label" for="tcpL">TCP</label>
                </div>
            </div>
            <div class="col-md-2">
                <button class="btn btn-warning w-100" @onclick="LendBook">
                    <i class="bi bi-box-arrow-right"></i> Выдать
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Tabs: By Reader / Overdue -->
<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <button class="nav-link @(activeTab == "reader" ? "active" : "")" @onclick='() => SwitchTab("reader")'>
            По читателю
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(activeTab == "overdue" ? "active" : "")" @onclick='() => SwitchTab("overdue")'>
            <i class="bi bi-exclamation-triangle"></i> Просроченные
        </button>
    </li>
</ul>

@if (activeTab == "reader")
{
    <div class="row mb-3 g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label">ID читателя</label>
            <input type="number" class="form-control" @bind="viewReaderId" />
        </div>
        <div class="col-md-2">
            <button class="btn btn-primary" @onclick="LoadReaderLoans">
                <i class="bi bi-search"></i> Показать
            </button>
        </div>
    </div>
}

@if (isLoading)
{
    <div class="text-center py-4"><div class="spinner-border text-primary"></div></div>
}
else if (loans != null)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Книга</th>
                    <th>Читатель</th>
                    <th>Дата выдачи</th>
                    <th>Срок возврата</th>
                    <th>Возвращена</th>
                    <th>Статус</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var l in loans)
                {
                    <tr class="@(l.IsOverdue && l.ReturnDate == null ? "table-danger" : "")">
                        <td>@l.Id</td>
                        <td>@l.BookTitle</td>
                        <td>@l.ReaderName</td>
                        <td>@l.LoanDate.ToString("dd.MM.yyyy")</td>
                        <td>@l.DueDate.ToString("dd.MM.yyyy")</td>
                        <td>@(l.ReturnDate?.ToString("dd.MM.yyyy") ?? "—")</td>
                        <td>
                            @if (l.ReturnDate != null)
                            {
                                <span class="badge bg-success">Возвращена</span>
                            }
                            else if (l.IsOverdue)
                            {
                                <span class="badge bg-danger">Просрочена</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">Активна</span>
                            }
                        </td>
                        <td>
                            @if (l.ReturnDate == null)
                            {
                                <button class="btn btn-sm btn-outline-success" @onclick="() => ReturnBook(l.Id)">
                                    <i class="bi bi-check-lg"></i> Вернуть
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <p class="text-muted">Записей: @loans.Count</p>
}

@code {
    private List<LoanDto>? loans;
    private bool isLoading, useTcp, isError;
    private string? message;
    private string activeTab = "reader";
    private int lendBookId, lendReaderId, viewReaderId;

    [SupplyParameterFromQuery] public int? readerId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (readerId.HasValue)
        {
            viewReaderId = readerId.Value;
            await LoadReaderLoans();
        }
    }

    private async Task SwitchTab(string tab)
    {
        activeTab = tab;
        loans = null;
        if (tab == "overdue") await LoadOverdueLoans();
    }

    private async Task LoadReaderLoans()
    {
        if (viewReaderId <= 0) return;
        isLoading = true;
        try { loans = await Api.GetLoansByReaderAsync(Session.Token!, viewReaderId, useTcp); }
        catch (Exception ex) { message = ErrorHandler.HandleException(ex); isError = true; }
        finally { isLoading = false; }
    }

    private async Task LoadOverdueLoans()
    {
        isLoading = true;
        try { loans = await Api.GetOverdueLoansAsync(Session.Token!, useTcp); }
        catch (Exception ex) { message = ErrorHandler.HandleException(ex); isError = true; }
        finally { isLoading = false; }
    }

    private async Task LendBook()
    {
        try
        {
            var loan = await Api.LendBookAsync(Session.Token!, lendBookId, lendReaderId, useTcp);
            message = $"Книга \"{loan.BookTitle}\" выдана читателю {loan.ReaderName}. Срок: {loan.DueDate:dd.MM.yyyy}";
            isError = false;
            if (activeTab == "reader" && viewReaderId == lendReaderId) await LoadReaderLoans();
        }
        catch (Exception ex) { message = ErrorHandler.HandleException(ex); isError = true; }
    }

    private async Task ReturnBook(int loanId)
    {
        try
        {
            var loan = await Api.ReturnBookAsync(Session.Token!, loanId, useTcp);
            message = $"Книга \"{loan.BookTitle}\" возвращена.";
            isError = false;
            if (activeTab == "overdue") await LoadOverdueLoans();
            else if (viewReaderId > 0) await LoadReaderLoans();
        }
        catch (Exception ex) { message = ErrorHandler.HandleException(ex); isError = true; }
    }
}

@page "/readers"
@inject LibraryApiClient Api
@inject SessionService Session
@inject NavigationManager Nav

@if (!Session.IsAuthenticated || !Session.IsLibrarian) { Nav.NavigateTo("/"); return; }

<h3><i class="bi bi-people"></i> Читатели</h3>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible fade show">
        @message
        <button type="button" class="btn-close" @onclick="() => message = null"></button>
    </div>
}

<div class="row mb-3">
    <div class="col">
        <button class="btn btn-success" @onclick="ShowAddForm">
            <i class="bi bi-person-plus"></i> Зарегистрировать читателя
        </button>
        <div class="form-check d-inline-block ms-3">
            <input class="form-check-input" type="checkbox" @bind="useTcp" id="tcpR" />
            <label class="form-check-label" for="tcpR">TCP</label>
        </div>
    </div>
</div>

@if (showForm)
{
    <div class="card mb-3 border-success">
        <div class="card-header bg-success text-white">Новый читатель</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">ФИО *</label>
                    <input class="form-control" @bind="formReader.FullName" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Email *</label>
                    <input type="email" class="form-control" @bind="formReader.Email" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Телефон</label>
                    <input class="form-control" @bind="formReader.Phone" />
                </div>
            </div>
            <div class="mt-3">
                <button class="btn btn-success" @onclick="RegisterReader">
                    <i class="bi bi-check-lg"></i> Зарегистрировать
                </button>
                <button class="btn btn-secondary ms-2" @onclick="() => showForm = false">Отмена</button>
            </div>
        </div>
    </div>
}

@if (isLoading)
{
    <div class="text-center py-4"><div class="spinner-border text-primary"></div></div>
}
else if (readers != null)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>ФИО</th>
                    <th>Email</th>
                    <th>Телефон</th>
                    <th>Дата регистрации</th>
                    <th>Статус</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in readers)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td><strong>@r.FullName</strong></td>
                        <td>@r.Email</td>
                        <td>@r.Phone</td>
                        <td>@r.RegisteredDate.ToString("dd.MM.yyyy")</td>
                        <td>
                            <span class="badge @(r.IsActive ? "bg-success" : "bg-secondary")">
                                @(r.IsActive ? "Активен" : "Неактивен")
                            </span>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-info" @onclick="() => ViewLoans(r.Id)">
                                <i class="bi bi-list-ul"></i> Выдачи
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <p class="text-muted">Всего читателей: @readers.Count</p>
}

@code {
    private List<ReaderDto>? readers;
    private bool isLoading = true, showForm, useTcp, isError;
    private string? message;
    private ReaderDto formReader = new();

    protected override async Task OnInitializedAsync() => await LoadReaders();

    private async Task LoadReaders()
    {
        isLoading = true;
        try
        {
            readers = await Api.GetAllReadersAsync(Session.Token!, useTcp);
        }
        catch (Exception ex)
        {
            message = ErrorHandler.HandleException(ex); isError = true;
        }
        finally { isLoading = false; }
    }

    private void ShowAddForm()
    {
        formReader = new ReaderDto();
        showForm = true;
    }

    private async Task RegisterReader()
    {
        try
        {
            var added = await Api.RegisterReaderAsync(Session.Token!, formReader, useTcp);
            message = $"Читатель \"{added.FullName}\" зарегистрирован (ID: {added.Id}).";
            isError = false; showForm = false;
            await LoadReaders();
        }
        catch (Exception ex) { message = ErrorHandler.HandleException(ex); isError = true; }
    }

    private void ViewLoans(int readerId) => Nav.NavigateTo($"/loans?readerId={readerId}");
}
